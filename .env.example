# Copy this file to .env and fill in your own keys. Never commit .env.
# The pipeline reads keys ONLY from environment variables - see agent/*.py.

# --- Stage 1: Composio toolkit check (required for that stage) ---
COMPOSIO_API_KEY=

# --- Stage 2: Deep research agent - pick ONE backend ---
# Option A: Anthropic directly (uses Claude's native web_search tool)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Option B: OpenRouter (uses OpenRouter's openrouter:web_search server tool,
# works across many tool-calling models through one API/key)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# If both ANTHROPIC_API_KEY and OPENROUTER_API_KEY are set, Anthropic is
# used by default. See agent/deep_research_agent.py: pick_backend().
